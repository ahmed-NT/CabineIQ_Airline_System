# AviationStack API key (for live flight routes)
AVIATIONSTACK_API_KEY=your_aviationstack_key

# Email notifications (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
